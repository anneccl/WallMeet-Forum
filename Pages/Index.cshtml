@page
@model TP5.Pages.IndexModel
@{
    ViewData["Title"] = "TP5-WallMeet";
    Layout = null;
    var currentUserId = HttpContext.Session.GetInt32("UserId");
}

@using TP5.Utilities

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/index.css" />
    
</head>
<body>

    <!-- Navbar -->
    <div class="navbar-wrapper">
        <nav class="navbar">
            <form method="post" asp-page-handler="Logout" style="margin:0;">
                <button type="submit" class="nav-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" x2="9" y1="12" y2="12" />
                    </svg>
                    Déconnexion
                </button>
            </form>

            <span class="nav-brand">TP5 - WallMeet</span>

            <div class="user-badge">
                <span class="name">@Model.UserFullName</span>
                <span class="mail">@Model.UserMail</span>
                <span class="role">@(Model.IsAdmin ? "Admin" : "Membre")</span>
            </div>
        </nav>
    </div>

    <main class="page">

        <!-- Titre -->
        <h1 class="page-title">Poster un message</h1>

        <!-- Composer -->
        <div class="composer card card-md">
            <form method="post" asp-page-handler="AddMessage">

                <textarea name="Content"
                          rows="4"
                          placeholder="Écrivez votre message ici…"
                          required></textarea>

                <div class="actions">
                    <button type="submit" class="btn-publish">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;">
                            <path d="m22 2-7 20-4-9-9-4Z" />
                            <path d="M22 2 11 13" />
                        </svg>
                        Publier
                    </button>
                </div>
            </form>
        </div>

        <!-- Section Posts -->
        <div class="section-header">
            <h2>Posts</h2>
            <div class="section-line"></div>
        </div>

        @if (Model.Messages == null || !Model.Messages.Any())
        {
            <p class="empty-state">Aucun post pour l'instant. Soyez le premier !</p>
        }
        else
        {
            <div class="posts-list">
                @foreach (var message in Model.Messages)
                {
                    var canDeleteMessage = Model.IsAdmin || message.UserId == currentUserId;

                    <article class="post-card">

                        <!-- Corps du post -->
                        <div class="post-body">
                            <div class="post-header">
                                <div class="post-meta">
                                    <span class="post-author">@message.User?.FirstName @message.User?.LastName</span>
                                    <span class="post-date">@message.Date.FormaterDate()  </span>
                                </div>

                                @if (canDeleteMessage)
                                {
                                    <form method="post" asp-page-handler="DeleteMessage" style="margin:0;"
                                          onsubmit="return confirm('Supprimer ce message ?');">
                                        <input type="hidden" name="messageId" value="@message.Id" />
                                        <button type="submit" class="btn-delete" title="Supprimer">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M3 6h18" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
                                                <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </button>
                                    </form>
                                }
                            </div>

                            <p class="post-content">@message.Content</p>
                        </div>

                        <!-- Commentaires -->
                        <div class="post-comments">
                            <div class="comments-header">
                                @(message.Comments?.Count ?? 0) commentaire@((message.Comments?.Count ?? 0) != 1 ? "s" : "")
                            </div>

                            @if (message.Comments != null && message.Comments.Any())
                            {
                                <div class="comments-list">
                                    @foreach (var comment in message.Comments.OrderBy(c => c.Date))
                                    {
                                        var canDeleteComment = Model.IsAdmin || comment.UserId == currentUserId;

                                        <div class="comment">
                                            <div class="comment-main">
                                                <div class="comment-meta">
                                                    <span class="comment-author">@comment.User?.FirstName @comment.User?.LastName</span>
                                                    <span class="comment-time">· @comment.Date.FormaterDateCourt()</span>
                                                </div>
                                                <p class="comment-content">@comment.Content</p>
                                            </div>

                                            @if (canDeleteComment)
                                            {
                                                <form method="post" asp-page-handler="DeleteComment" style="margin:0;"
                                                      onsubmit="return confirm('Supprimer ce commentaire ?');">
                                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                                    <button type="submit" class="btn-delete" title="Supprimer">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                            <path d="M18 6 6 18" />
                                                            <path d="m6 6 12 12" />
                                                        </svg>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Formulaire de réponse -->
                            <form method="post" asp-page-handler="AddComment" class="reply-form">
                                <input type="hidden" name="messageId" value="@message.Id" />
                                <input type="text" name="Content" placeholder="Répondre…" required />
                                <button type="submit" class="btn-reply" title="Envoyer">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="m22 2-7 20-4-9-9-4Z" />
                                        <path d="M22 2 11 13" />
                                    </svg>
                                </button>
                            </form>
                        </div>

                    </article>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-page="/Index" asp-route-pageNumber="@(Model.CurrentPage - 1)">‹ Préc</a>
                    }
                    else
                    {
                        <span class="disabled">‹ Préc</span>
                    }

                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        if (p == Model.CurrentPage)
                        {
                            <span class="current">@p</span>
                        }
                        else
                        {
                            <a asp-page="/Index" asp-route-pageNumber="@p">@p</a>
                        }
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-page="/Index" asp-route-pageNumber="@(Model.CurrentPage + 1)">Suiv ›</a>
                    }
                    else
                    {
                        <span class="disabled">Suiv ›</span>
                    }
                </nav>
            }
        }

    </main>

</body>
</html>
